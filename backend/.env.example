# =============================================================
# .env.example — Template for environment variables
#
# For local development with Docker:
#   cp .env.dev .env.dev.local   # adjust if needed
#
# For production:
#   cp .env.example .env         # fill in every value
# =============================================================

# ---- Database -----------------------------------------------
POSTGRES_USER=yourdbuser
POSTGRES_DB=yourdbname
POSTGRES_PASSWORD=yourdbpassword
POSTGRES_PORT=5432
# In Docker Compose this is the service name ("db").
# For a local (non-Docker) setup use "localhost".
POSTGRES_HOST=db

# Must match the four fields above.
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<db>
SQLALCHEMY_DATABASE_URL=postgresql+asyncpg://yourdbuser:yourdbpassword@db:5432/yourdbname

# ---- Redis --------------------------------------------------
# In Docker Compose use "redis" (service name).
REDIS_URL=redis://redis:6379/0

# ---- Authentication -----------------------------------------
# Generate with: openssl rand -hex 32
SECRET_KEY=
SECURITY_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRES=7
VERIFY_TOKEN_EXPIRES=24

# ---- Email service ------------------------------------------
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_PORT=587
MAIL_HOST=
MAIL_FROM_NAME=MarketMind

# ---- External APIs ------------------------------------------
# Polygon.io / Massive (required for price + news ingestion)
MASSIVE_API_KEY=

# Alpha Vantage (alternative data source)
ALPHA_VANTAGE_API_KEY=

# OpenAI (optional, used by the AI module)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- CORS ---------------------------------------------------
CORS_ORIGINS=["http://localhost:5173"]
FRONTEND_URL=http://localhost:5173

# ---- Overwrite Celery default configs -----------------------
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
